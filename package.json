{
  "name": "purerun-app",
  "version": "0.1.0",
  "description": "A customized dashboard for Garmin Connect with AI-powered training plans.",
  "license": "MIT",
  "private": false,
  "scripts": {
    "dev": "next dev",
    "build": "npx prisma db push --accept-data-loss && next build",
    "start": "next start",
    "test:pwa": "npm run build && npm run start",
    "tunnel": "npx @cloudflare/cloudflared tunnel --url http://localhost:3000",
    "lint": "eslint",
    "setup": "npm install && npx prisma db push && npm run dev"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@libsql/client": "^0.17.4",
    "@prisma/adapter-libsql": "^7.8.0",
    "@prisma/client": "^6.19.3",
    "@tailwindcss/typography": "^0.5.20",
    "@types/leaflet": "^1.9.21",
    "echarts": "^6.1.0",
    "echarts-for-react": "^3.0.6",
    "garmin-connect": "^1.6.2",
    "leaflet": "^1.9.4",
    "leaflet-defaulticon-compatibility": "^0.1.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
