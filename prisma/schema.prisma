generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

model GarminStats {
  id              Int      @id @default(1)
  weeklyKm        Float
  avgHr           Float
  avgPaceStr      String
  estimatedVdot   Float
  totalActivities Int
  updatedAt       DateTime @updatedAt
}

model GarminActivity {
  activityId      BigInt   @id
  source          String   @default("Garmin") // "Garmin" or "Strava"
  activityName    String
  date            DateTime // 建議從 String 更改為 DateTime，方便日後範圍查詢與排序
  distanceKm      Float    // 距離（公里），維持 Float
  durationMin     Float    // 從 Int 變更為 Float，支援小數分鐘（例如 42.5）
  avgHr           Int?     // 從 Float? 變更為 Int?，心率通常為整數
  maxHr           Int?     // 從 Float? 變更為 Int?，心率通常為整數
  avgPaceMinPerKm Float?   // 配速轉換成十進位（例如 5.5 = 5分30秒/公里），維持 Float
  avgPaceStr      String?  // 配速字串（例如 "5:30"），適合直接顯示
  vO2MaxValue     Float?   // 最大攝氧量，維持 Float
  calories        Int?     // 消耗熱量，建議為 Int?
  activityTypeKey String   // 活動類型（例如 running）
  elevationGain   Float?   // 總爬升高度（公尺），維持 Float
  cadence         Int?     // 步頻（spm），維持 Int?
  strideLength    Float?   // 步幅（公尺），維持 Float?
  trainingEffect  Float?   // 訓練效果（TE），維持 Float?
  
  routeData       String?  // JSON array of [lat, lon] tuples
  metricsData     String?  // JSON array of detailed metrics (HR, Pace, Cadence)
  gpxFilePath     String?  // 新增：儲存 GPX 檔案在 public/gpx/ 的相對路徑

  // Advanced Professional Metrics
  trainingLoad        Float?  // Training Stress Score (TSS) or TRIMP
  timeInZones         String? // JSON string: { hrZones: [], paceZones: [] }
  verticalOscillation Float?  // 垂直振幅 (cm)
  groundContactTime   Int?    // 觸地時間 (ms)
  splitsData          String? // JSON string: Array of laps/splits
}

model TrainingPlan {
  id             String    @id @default(uuid())
  startDate      String // YYYY-MM-DD
  endDate        String // YYYY-MM-DD
  weeklyAnalysis String
  createdAt      DateTime  @default(now())
  workouts       Workout[]
}

model Workout {
  id               String       @id @default(uuid())
  planId           String
  plan             TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  date             String // YYYY-MM-DD
  workoutType      String // Recovery | Interval | Tempo | LongRun | Rest
  title            String
  targetPace       String?
  targetHrZone     Int?
  description      String
  status           String       @default("Pending") // Pending | Completed | Missed
  actualActivityId BigInt?
  actualDistance   Float?
  actualDuration   Int?
  actualAvgHr      Float?
  actualPaceStr    String?
  complianceRate   Float? // Percentage of matching target
  aiFeedback       String? // Detailed qualitative feedback generated by AI
}

model FitnessStatus {
  id        String   @id @default(uuid())
  date      String   // YYYY-MM-DD
  ctl       Float    // Chronic Training Load (Fitness)
  atl       Float    // Acute Training Load (Fatigue)
  tsb       Float    // Training Stress Balance (Form)
  acwr      Float    // Acute/Chronic Workload Ratio
  createdAt DateTime @default(now())

  @@unique([date])
}
